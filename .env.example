# ============================================================
# NexPC Environment Configuration Template
# ============================================================
# Do NOT place your actual API keys in this file. 
# Rename this file to '.env' locally to use it in your app.

# --- Auth Security ---
# Secret key used by Flask to securely sign the session cookie
SECRET_KEY=generate_a_strong_random_key_here

# --- Database Integration (MySQL) ---
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DB=ecommerce_chatbot

# --- AI Integrations (Groq + LangChain + Pinecone) ---
# Groq: For the LLaMA-3.3-70b-versatile LLM inference (Tool calling & RAG)
GROQ_API_KEY=gsk_xxx

# HuggingFace: For vector embeddings (BAAI/bge-small-en-v1.5)
HF_API_KEY=hf_xxx

# Pinecone: For cloud vector storage and similarity retrieval (RAG)
PINECONE_API_KEY=pc-sk-xxx
PINECONE_INDEX_NAME=ecommerce-chatbot-project

# NVIDIA (Optional): If utilizing specific NVIDIA API wrappers
NVIDIA_API_KEY=nvapi-xxx
